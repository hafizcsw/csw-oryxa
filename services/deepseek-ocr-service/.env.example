# Bearer key the Supabase `deepseek-ocr-service` adapter must send.
# Generate with: openssl rand -hex 32
DEEPSEEK_OCR_SERVICE_KEY=change-me

# Inference device. Use `cuda` on GPU host; `cpu` only for skeleton boot.
MODEL_DEVICE=cuda

# Hugging Face / local model identifier. Skeleton ignores this.
MODEL_NAME=deepseek-ai/DeepSeek-OCR-2

# Per-request limits.
MAX_FILE_MB=25
REQUEST_TIMEOUT_SECONDS=120

# debug | info | warning | error
LOG_LEVEL=info
