# ─────────────────────────────────────────────────────────────
# paddle-service environment file
# Copy to `.env` on the VPS:   cp .env.example .env
# Then edit values and run:    docker compose up -d
# ─────────────────────────────────────────────────────────────

# REQUIRED — long random string. The same value goes into Supabase
# secret PADDLE_API_KEY so the edge function can authenticate.
# Generate with:  openssl rand -hex 32
PADDLE_API_KEY=replace-me-with-openssl-rand-hex-32

# REQUIRED — public hostname Caddy will obtain a TLS cert for.
# Must already point (A/AAAA record) to this VPS public IP.
PADDLE_HOSTNAME=paddle.example.com

# OPTIONAL — email used by Let's Encrypt for cert expiry notices.
ACME_EMAIL=ops@example.com

# OPTIONAL — tuning. Defaults are safe.
DOWNLOAD_TIMEOUT_S=20
MAX_BYTES=26214400
